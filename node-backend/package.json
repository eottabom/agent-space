{
  "name": "agent-space-node-backend",
  "version": "0.9.10",
  "description": "Node.js backend for Agent Space — replaces Java/Spring Boot",
  "main": "dist/electron.js",
  "scripts": {
    "postinstall": "node scripts/fix-pty-permissions.js",
    "version:read": "node scripts/version.js read",
    "version:sync": "node scripts/version.js sync",
    "build": "tsc",
    "start": "node dist/index.js",
    "build:frontend": "cd ../frontend && npm install && npm run build",
    "setup": "npm install && npm run build:frontend && npm run build",
    "launch": "npm run setup && npm start",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build:frontend && npm run build && electron-builder"
  },
  "dependencies": {
    "express": "^4.19.2",
    "node-pty": "^1.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.agentspace.app",
    "productName": "AgentSpace",
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "dist/**",
      "node_modules/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icons/256x256.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icons"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
